+// @desc    Admin views single extension request with partner performance
+// @route   GET /api/job-interests/admin/extension-requests/:id
+// @access  Admin
+exports.getExtensionRequest = async (req, res) => {
+    try {
+        const request = await LimitExtensionRequest.findById(req.params.id)
+            .populate({
+                path: 'partner',
+                select: 'firstName lastName firmName metrics verificationStatus subscription'
+            })
+            .populate('job', 'title category location salary metrics')
+            .populate('jobInterest')
+            .populate('user', 'email mobile')
+            .populate('reviewedBy', 'email role');
+
+        if (!request) {
+            return res.status(404).json({
+                success: false,
+                message: 'Extension request not found'
+            });
+        }
+
+        // Get partner's performance on this specific job
+        const Candidate = require('../models/Candidate');
+        const partnerJobPerformance = await Candidate.aggregate([
+            {
+                $match: {
+                    submittedBy: request.partner._id,
+                    job: request.job._id
+                }
+            },
+            {
+                $group: {
+                    _id: '$status',
+                    count: { $sum: 1 }
+                }
+            }
+        ]);
+
+        // Get partner's overall performance
+        const overallPerformance = await Candidate.aggregate([
+            { $match: { submittedBy: request.partner._id } },
+            { $group: { _id: '$status', count: { $sum: 1 } } }
+        ]);
+
+        res.json({
+            success: true,
+            data: {
+                request,
+                partnerPerformance: {
+                    onThisJob: partnerJobPerformance.reduce((acc, item) => {
+                        acc[item._id] = item.count;
+                        return acc;
+                    }, {}),
+                    overall: overallPerformance.reduce((acc, item) => {
+                        acc[item._id] = item.count;
+                        return acc;
+                    }, {}),
+                    metrics: request.partner.metrics
+                }
+            }
+        });
+    } catch (error) {
+        res.status(500).json({
+            success: false,
+            message: 'Failed to fetch extension request',
+            error: error.message
+        });
+    }
+};
