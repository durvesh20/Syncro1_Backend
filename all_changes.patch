+// @desc    Partner requests limit extension
+// @route   POST /api/job-interests/:jobId/request-extension
+// @access  Staffing Partner
+exports.requestLimitExtension = async (req, res) => {
+    try {
+        const { requestedAdditional, reason } = req.body;
+
+        if (!requestedAdditional || requestedAdditional < 1 || requestedAdditional > 10) {
+            return res.status(400).json({
+                success: false,
+                message: 'Please specify how many additional submissions you need (1-10)'
+            });
+        }
+
+        if (!reason || reason.trim().length < 10) {
+            return res.status(400).json({
+                success: false,
+                message: 'Please provide a reason (minimum 10 characters)'
+            });
+        }
+
+        const partner = await StaffingPartner.findOne({ user: req.user._id });
+
+        const interest = await JobInterest.findOne({
+            partner: partner._id,
+            job: req.params.jobId,
+            status: 'ACTIVE'
+        }).populate('job', 'title');
+
+        if (!interest) {
+            return res.status(404).json({
+                success: false,
+                message: 'You have not shown interest in this job. Please show interest first.'
+            });
+        }
+
+        if (interest.submissionCount < interest.submissionLimit) {
+            return res.status(400).json({
+                success: false,
+                message: `You still have ${interest.submissionLimit - interest.submissionCount} submission slots remaining. Use them first.`
+            });
+        }
+
+        // Check if already has pending request
+        const existingRequest = await LimitExtensionRequest.findOne({
+            partner: partner._id,
+            job: req.params.jobId,
+            status: 'PENDING'
+        });
+
+        if (existingRequest) {
+            return res.status(400).json({
+                success: false,
+                message: 'You already have a pending extension request for this job',
+                data: existingRequest
+            });
+        }
+
+        const request = await LimitExtensionRequest.create({
+            partner: partner._id,
+            job: req.params.jobId,
+            jobInterest: interest._id,
+            user: req.user._id,
+            requestedAdditional: parseInt(requestedAdditional),
+            reason: reason.trim()
+        });
+
+        // Notify admin
+        const notifyAdmin = async () => {
+            try {
+                const notificationEngine = require('../services/notificationEngine');
+                const adminUsers = await User.find({ role: 'admin' });
+                for (const admin of adminUsers) {
+                    await notificationEngine.send({
+                        recipientId: admin._id,
+                        type: 'SYSTEM_ANNOUNCEMENT',
+                        title: `Limit extension request from ${partner.firmName}`,
+                        message: `${partner.firmName} is requesting ${requestedAdditional} additional submissions for job "${interest.job?.title}". Reason: ${reason.trim().substring(0, 100)}`,
+                        data: {
+                            entityType: 'LimitExtensionRequest',
+                            entityId: request._id,
+                            actionUrl: `/admin/extension-requests/${request._id}`
+                        },
+                        channels: { inApp: true, email: false },
+                        priority: 'medium'
+                    });
+                }
+            } catch (err) {
+                console.error('[INTEREST] Admin notification failed:', err.message);
+            }
+        };
+
+        notifyAdmin();
+
+        res.status(201).json({
+            success: true,
+            message: 'Extension request submitted. Admin will review and respond.',
+            data: {
+                requestId: request._id,
+                requestedAdditional,
+                currentLimit: interest.submissionLimit,
+                status: 'PENDING'
+            }
+        });
+    } catch (error) {
+        console.error('[INTEREST] Extension request error:', error);
+        res.status(500).json({
+            success: false,
+            message: 'Failed to submit extension request',
+            error: error.message
+        });
+    }
+};
