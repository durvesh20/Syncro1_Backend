+// @desc    Partner shows interest in a job
+// @route   POST /api/job-interests/:jobId/interest
+// @access  Staffing Partner
+exports.showInterest = async (req, res) => {
+    try {
+        const partner = await StaffingPartner.findOne({ user: req.user._id });
+
+        if (!partner) {
+            return res.status(404).json({
+                success: false,
+                message: 'Partner profile not found'
+            });
+        }
+
+        const job = await Job.findById(req.params.jobId);
+
+        if (!job) {
+            return res.status(404).json({
+                success: false,
+                message: 'Job not found'
+            });
+        }
+
+        if (job.status !== 'ACTIVE' || job.approvalStatus !== 'ACTIVE') {
+            return res.status(400).json({
+                success: false,
+                message: 'This job is not active'
+            });
+        }
+
+        // Check if already interested
+        const existing = await JobInterest.findOne({
+            partner: partner._id,
+            job: job._id
+        });
+
+        if (existing) {
+            if (existing.status === 'ACTIVE') {
+                return res.status(400).json({
+                    success: false,
+                    message: 'You have already shown interest in this job',
+                    data: existing
+                });
+            }
+
+            // Reactivate if withdrawn
+            existing.status = 'ACTIVE';
+            await existing.save();
+
+            return res.json({
+                success: true,
+                message: 'Interest reactivated for this job',
+                data: existing
+            });
+        }
+
+        // Create new interest
+        const interest = await JobInterest.create({
+            partner: partner._id,
+            job: job._id,
+            user: req.user._id,
+            status: 'ACTIVE',
+            submissionCount: 0,
+            submissionLimit: 5
+        });
+
+        // Update job interest count
+        await Job.findByIdAndUpdate(job._id, {
+            $inc: { 'metrics.interestedPartners': 1 }
+        });
+
+        // Update partner metrics
+        await StaffingPartner.findByIdAndUpdate(partner._id, {
+            $inc: { 'metrics.totalJobsInterested': 1 }
+        });
+
+        console.log(`[INTEREST] ✅ ${partner.firmName} interested in: ${job.title}`);
+
+        res.status(201).json({
+            success: true,
+            message: 'Interest registered successfully. You can now submit up to 5 candidates.',
+            data: {
+                interestId: interest._id,
+                jobId: job._id,
+                jobTitle: job.title,
+                submissionLimit: interest.submissionLimit,
+                submissionCount: interest.submissionCount,
+                remainingSlots: interest.submissionLimit - interest.submissionCount
+            }
+        });
+    } catch (error) {
+        if (error.code === 11000) {
+            return res.status(400).json({
+                success: false,
+                message: 'You have already shown interest in this job'
+            });
+        }
+        console.error('[INTEREST] Show interest error:', error);
+        res.status(500).json({
+            success: false,
+            message: 'Failed to register interest',
+            error: error.message
+        });
+    }
+};
+
+// @desc    Partner withdraws interest from a job
+// @route   DELETE /api/job-interests/:jobId/interest
+// @access  Staffing Partner
+exports.withdrawInterest = async (req, res) => {
+    try {
+        const partner = await StaffingPartner.findOne({ user: req.user._id });
+
+        const interest = await JobInterest.findOne({
+            partner: partner._id,
+            job: req.params.jobId,
+            status: 'ACTIVE'
+        });
+
+        if (!interest) {
+            return res.status(404).json({
+                success: false,
+                message: 'No active interest found for this job'
+            });
+        }
+
+        if (interest.submissionCount > 0) {
+            return res.status(400).json({
+                success: false,
+                message: 'Cannot withdraw interest after submitting candidates'
+            });
+        }
+
+        interest.status = 'WITHDRAWN';
+        await interest.save();
+
+        await Job.findByIdAndUpdate(req.params.jobId, {
+            $inc: { 'metrics.interestedPartners': -1 }
+        });
+
+        res.json({
+            success: true,
+            message: 'Interest withdrawn successfully'
+        });
+    } catch (error) {
+        res.status(500).json({
+            success: false,
+            message: 'Failed to withdraw interest',
+            error: error.message
+        });
+    }
+};
