+// ================================================================
+// PARTNER PERFORMANCE
+// ================================================================
+
+// @desc    Get partner performance analytics
+// @route   GET /api/job-interests/my-performance
+// @access  Staffing Partner
+exports.getMyPerformance = async (req, res) => {
+    try {
+        const partner = await StaffingPartner.findOne({ user: req.user._id });
+        const Candidate = require('../models/Candidate');
+
+        // Overall status breakdown
+        const statusBreakdown = await Candidate.aggregate([
+            { $match: { submittedBy: partner._id } },
+            { $group: { _id: '$status', count: { $sum: 1 } } }
+        ]);
+
+        const breakdown = statusBreakdown.reduce((acc, item) => {
+            acc[item._id] = item.count;
+            return acc;
+        }, {});
+
+        const totalSubmissions = Object.values(breakdown).reduce((a, b) => a + b, 0);
+        const shortlisted = (breakdown.SHORTLISTED || 0) + (breakdown.INTERVIEW_SCHEDULED || 0) +
+            (breakdown.INTERVIEWED || 0) + (breakdown.OFFERED || 0) +
+            (breakdown.OFFER_ACCEPTED || 0) + (breakdown.JOINED || 0);
+        const placed = breakdown.JOINED || 0;
+
+        // Job-wise performance
+        const jobPerformance = await Candidate.aggregate([
+            { $match: { submittedBy: partner._id } },
+            {
+                $group: {
+                    _id: '$job',
+                    total: { $sum: 1 },
+                    statuses: { $push: '$status' }
+                }
+            },
+            {
+                $lookup: {
+                    from: 'jobs',
+                    localField: '_id',
+                    foreignField: '_id',
+                    as: 'jobDetails'
+                }
+            },
+            { $unwind: { path: '$jobDetails', preserveNullAndEmpty: true } },
+            {
+                $project: {
+                    jobTitle: '$jobDetails.title',
+                    total: 1,
+                    statuses: 1
+                }
+            },
+            { $sort: { total: -1 } },
+            { $limit: 10 }
+        ]);
+
+        // Interest stats
+        const totalInterested = await JobInterest.countDocuments({
+            partner: partner._id,
+            status: 'ACTIVE'
+        });
+
+        // Conversion rates
+        const submissionToShortlist = totalSubmissions > 0
+            ? Math.round((shortlisted / totalSubmissions) * 100)
+            : 0;
+
+        const shortlistToPlacement = shortlisted > 0
+            ? Math.round((placed / shortlisted) * 100)
+            : 0;
+
+        const submissionToPlacement = totalSubmissions > 0
+            ? Math.round((placed / totalSubmissions) * 100)
+            : 0;
+
+        res.json({
+            success: true,
+            data: {
+                summary: {
+                    totalJobsInterested: totalInterested,
+                    totalSubmissions,
+                    shortlisted,
+                    placed,
+                    earnings: partner.metrics.totalEarnings || 0
+                },
+                conversionRates: {
+                    submissionToShortlist: `${submissionToShortlist}%`,
+                    shortlistToPlacement: `${shortlistToPlacement}%`,
+                    overallPlacementRate: `${submissionToPlacement}%`
+                },
+                statusBreakdown: breakdown,
+                jobWisePerformance: jobPerformance,
+                metrics: partner.metrics
+            }
+        });
+    } catch (error) {
+        res.status(500).json({
+            success: false,
+            message: 'Failed to fetch performance data',
+            error: error.message
+        });
+    }
+};
+
+// @desc    Admin gets partner performance detail
+// @route   GET /api/job-interests/admin/partner-performance/:partnerId
+// @access  Admin
+exports.getPartnerPerformance = async (req, res) => {
+    try {
+        const partner = await StaffingPartner.findById(req.params.partnerId);
+
+        if (!partner) {
+            return res.status(404).json({
+                success: false,
+                message: 'Partner not found'
+            });
+        }
+
+        const Candidate = require('../models/Candidate');
+
+        const statusBreakdown = await Candidate.aggregate([
+            { $match: { submittedBy: partner._id } },
+            { $group: { _id: '$status', count: { $sum: 1 } } }
+        ]);
+
+        const breakdown = statusBreakdown.reduce((acc, item) => {
+            acc[item._id] = item.count;
+            return acc;
+        }, {});
+
+        const totalSubmissions = Object.values(breakdown).reduce((a, b) => a + b, 0);
+        const placed = breakdown.JOINED || 0;
+        const shortlisted = (breakdown.SHORTLISTED || 0) + (breakdown.INTERVIEW_SCHEDULED || 0) +
+            (breakdown.INTERVIEWED || 0) + (breakdown.OFFERED || 0) +
+            (breakdown.OFFER_ACCEPTED || 0) + (breakdown.JOINED || 0);
+
+        // Recent submissions
+        const recentSubmissions = await Candidate.find({ submittedBy: partner._id })
+            .populate('job', 'title')
+            .populate('company', 'companyName')
+            .sort({ createdAt: -1 })
+            .limit(10)
+            .select('firstName lastName status job company createdAt');
+
+        // Extension requests history
+        const extensionRequests = await LimitExtensionRequest.find({
+            partner: partner._id
+        })
+            .populate('job', 'title')
+            .sort({ createdAt: -1 })
+            .limit(5);
+
+        const totalInterested = await JobInterest.countDocuments({
+            partner: partner._id,
+            status: 'ACTIVE'
+        });
+
+        res.json({
+            success: true,
+            data: {
+                partner: {
+                    _id: partner._id,
+                    name: `${partner.firstName} ${partner.lastName}`,
+                    firmName: partner.firmName,
+                    verificationStatus: partner.verificationStatus,
+                    subscription: partner.subscription,
+                    metrics: partner.metrics
+                },
+                performance: {
+                    totalJobsInterested: totalInterested,
+                    totalSubmissions,
+                    shortlisted,
+                    placed,
+                    conversionRates: {
+                        submissionToShortlist: totalSubmissions > 0
+                            ? `${Math.round((shortlisted / totalSubmissions) * 100)}%`
+                            : '0%',
+                        overallPlacementRate: totalSubmissions > 0
+                            ? `${Math.round((placed / totalSubmissions) * 100)}%`
+                            : '0%'
+                    },
+                    statusBreakdown: breakdown
+                },
+                recentSubmissions,
+                extensionRequests
+            }
+        });
+    } catch (error) {
+        res.status(500).json({
+            success: false,
+            message: 'Failed to fetch partner performance',
+            error: error.message
+        });
+    }
+};
