+    } else if (shouldWarn) {
+      warningMessage = '\n\n⚠️ Warning: This job has 3+ rejected edit requests. Further rejections may result in discontinuation.';
+    }
+
+    if (editRequest.company.user) {
+      await notificationEngine.send({
