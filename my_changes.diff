+    res.json({
+      success: true,
+      message: 'Payout forfeited due to candidate early exit',
+      data: result
+    });
+  } catch (error) {
+    res.status(500).json({
+      success: false,
+      message: error.message || 'Failed to forfeit payout'
+    });
+  }
